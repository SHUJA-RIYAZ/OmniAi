{
  "manifest_version": 3,
  "name": "AI Context Bridge",
  "version": "0.2.0",
  "description": "Universal AI browser assistant: send VS Code context into ChatGPT, Claude, Gemini, DeepSeek, Kimi, Perplexity, and Z.ai.",
  "permissions": ["activeTab", "scripting", "storage", "tabs"],
  "host_permissions": [
    "http://127.0.0.1:8765/*",
    "http://localhost:8765/*",
    "https://chatgpt.com/*",
    "https://chat.openai.com/*",
    "https://claude.ai/*",
    "https://gemini.google.com/*",
    "https://chat.deepseek.com/*",
    "https://*.deepseek.com/*",
    "https://kimi.moonshot.cn/*",
    "https://www.kimi.com/*",
    "https://kimi.com/*",
    "https://kimi.ai/*",
    "https://www.perplexity.ai/*",
    "https://perplexity.ai/*",
    "https://chat.z.ai/*",
    "https://z.ai/*",
    "https://www.z.ai/*"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "AI Context Bridge"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://chatgpt.com/*",
        "https://chat.openai.com/*",
        "https://claude.ai/*",
        "https://gemini.google.com/*",
        "https://chat.deepseek.com/*",
        "https://*.deepseek.com/*",
        "https://kimi.moonshot.cn/*",
        "https://www.kimi.com/*",
        "https://kimi.com/*",
        "https://kimi.ai/*",
        "https://www.perplexity.ai/*",
        "https://perplexity.ai/*",
        "https://chat.z.ai/*",
        "https://z.ai/*",
        "https://www.z.ai/*"
      ],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}
